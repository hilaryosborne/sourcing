{
  "name": "@hilaryosborne/sourcing-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "A domain-agnostic event sourcing library — monorepo of individually publishable packages.",
  "license": "MIT",
  "author": "Hilary Osborne",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.14.0",
    "@hilaryosborne/sourcing": "workspace:^",
    "@hilaryosborne/sourcing-adapter-mongo": "workspace:^",
    "@hilaryosborne/sourcing-adapter-postgres": "workspace:^",
    "@hilaryosborne/sourcing-adapter-s3": "workspace:^",
    "@hilaryosborne/sourcing-persistence": "workspace:^",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "husky": "^9.1.0",
    "pg": "^8.21.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.0"
  }
}
